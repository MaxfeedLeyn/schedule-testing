                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "function randomInt(min, max) {",
                  "    return Math.floor(Math.random() * (max - min + 1)) + min;",
                  "}",
                  "",
                  "function randomBool() {",
                  "    return Math.random() < 0.5;",
                  "}",
                  "",
                  "function randomTime(hourStart) {",
                  "",
                  "    const startHour = hourStart;",
                  "    const endHour = startHour + 1;",
                  "",
                  "    return {",
                  "        startTime: `${String(startHour).padStart(2, \"0\")}:${Math.random() < 0.5 ? \"00\" : \"30\"}`,",
                  "        endTime: `${String(endHour).padStart(2, \"0\")}:${Math.random() < 0.5 ? \"20\" : \"50\"}`",
                  "    };",
                  "}",
                  "",
                  "const randomDescription =",
                  "    `semester_${Math.random().toString(36).substring(2, 8)}`;",
                  "",
                  "// Random year",
                  "const randomYear = randomInt(2028, 2035);",
                  "",
                  "// Random dates",
                  "const startDay = `${randomInt(1, 28).toString().padStart(2, \"0\")}/01/${randomYear}`;",
                  "const endDay = `${randomInt(1, 28).toString().padStart(2, \"0\")}/06/${randomYear}`;",
                  "",
                  "// Generate classes",
                  "const semesterClasses = [];",
                  "",
                  "for (let i = 1; i <= 4; i++) {",
                  "",
                  "    const times = randomTime(7 + i * 2);",
                  "",
                  "    semesterClasses.push({",
                  "        id: i,",
                  "        startTime: times.startTime,",
                  "        endTime: times.endTime,",
                  "        class_name: `${i}`",
                  "    });",
                  "}",
                  "",
                  "// Generate groups",
                  "const semesterGroups = [];",
                  "",
                  "const groupCount = randomInt(1, 3);",
                  "",
                  "for (let i = 1; i <= groupCount; i++) {",
                  "",
                  "    semesterGroups.push({",
                  "        id: i,",
                  "    });",
                  "}",
                  "",
                  "// Final payload",
                  "const semesterPayload = {",
                  "    description: randomDescription,",
                  "    year: randomYear,",
                  "    startDay: startDay,",
                  "    endDay: endDay,",
                  "    currentSemester: randomBool(),",
                  "    defaultSemester: randomBool(),",
                  "    disable: randomBool(),",
                  "    semester_days: [],",
                  "    semester_classes: semesterClasses,",
                  "    semester_groups: semesterGroups",
                  "};",
                  "",
                  "// Save variable",
                  "pm.collectionVariables.set(",
                  "    \"semester_payload\",",
                  "    JSON.stringify(semesterPayload)",
                  ");"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
