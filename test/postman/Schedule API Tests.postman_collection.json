  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "// Current time",
          "const currentTime = Date.now();",
          "",
          "// Stored expiration time",
          "const tokenExpirationTime = Number(",
          "    pm.collectionVariables.get(\"token_expiration_time\")",
          ");",
          "",
          "// Existing token",
          "const accessToken = pm.collectionVariables.get(\"access_token\");",
          "",
          "// Check whether token is missing or expired",
          "if (!accessToken || !tokenExpirationTime || currentTime >= tokenExpirationTime) {",
          "",
          "    console.log(\"Token missing or expired. Fetching new token...\");",
          "",
          "    pm.sendRequest({",
          "        url: pm.collectionVariables.get(\"auth_url\"),",
          "        method: \"POST\",",
          "",
          "        header: {",
          "            \"Content-Type\": \"application/json\"",
          "        },",
          "",
          "        body: {",
          "            mode: \"raw\",",
          "            raw: JSON.stringify({",
          "                email: pm.collectionVariables.get(\"email\"),",
          "                password: pm.collectionVariables.get(\"password\")",
          "            })",
          "        }",
          "",
          "    }, function (err, response) {",
          "",
          "        if (err) {",
          "            console.error(\"Token request failed:\", err);",
          "            return;",
          "        }",
          "",
          "        if (!response || response.code >= 400) {",
          "            console.error(\"Authentication failed:\", response.text());",
          "            return;",
          "        }",
          "",
          "        const jsonData = response.json();",
          "",
          "        console.log(\"Auth response:\", jsonData);",
          "",
          "        const newAccessToken = jsonData.token;",
          "        const newExpiresIn = jsonData.expires_in || 3600;",
          "",
          "        if (!newAccessToken) {",
          "            console.error(\"No access token returned!\");",
          "            return;",
          "        }",
          "",
          "        // Save token",
          "        pm.collectionVariables.set(\"access_token\", newAccessToken);",
          "",
          "        // Convert seconds -> milliseconds",
          "        const expirationTime = Date.now() + (newExpiresIn * 1000);",
          "",
          "        pm.collectionVariables.set(",
          "            \"token_expiration_time\",",
          "            expirationTime.toString()",
          "        );",
          "",
          "        console.log(\"New token stored successfully.\");",
          "    });",
          "",
          "} else {",
          "",
          "    console.log(\"Using existing token.\");",
          "}",
          "",
          "pm.request.headers.upsert({key: \"Authorization\", value: \"Bearer_\" + pm.collectionVariables.get(\"access_token\")});"
        ]
      }
    },
